# Copy this file to .env and fill in real values for your local environment.
# .env is gitignored — never commit secrets.

# --- Database ---
# Local dev default matches the docker-compose / k8s seed creds.
DATABASE_URL=postgresql://darwinist:darwinist@localhost:5432/darwinist

# --- Flask ---
# Local-dev fallback only. Production reads from the k8s Secret applied via
# .github/workflows/main.yml (secrets.FLASK_SECRET_KEY). Generate a real one
# with: python -c 'import secrets; print(secrets.token_urlsafe(64))'
SECRET_KEY=your-secret-key-here
FLASK_ENV=development

# --- CQC syndication API (contingency path) ---
# We currently ingest via the bulk monthly downloads at cqc.org.uk; the API
# is kept as fallback. Auth flow is documented in CQC's developer portal at
# https://api-portal.service.cqc.org.uk/ — register there to obtain keys.
CQC_PRIMARY_KEY=replace-with-your-primary-key
CQC_SECONDARY_KEY=replace-with-your-secondary-key
